# Kopieren nach .env (git-ignoriert) und ausfüllen. docker-compose.yml liest
# diese Werte automatisch, wenn eine .env-Datei im selben Verzeichnis liegt.

# JWT-Signierschlüssel für Login-Tokens. Wenn leer, wird beim ersten Start
# automatisch ein Schlüssel generiert und neben der DB abgelegt (data/jwt_secret.key)
# — für die meisten Setups reicht das, explizit setzen nur bei Bedarf (z.B. mehrere
# Backend-Instanzen, die denselben Schlüssel teilen müssen).
JWT_SECRET_KEY=

# SMTP-Zugangsdaten zum Versand von Bestätigungscodes (Registrierung, Passwort-
# Reset). Kein eigener Mailserver — Zustellung (SPF/DKIM/Reputation) übernimmt
# ein Transactional-Mail-Dienst. Standard hier: Resend (resend.com), kostenloser
# Account, API-Key als SMTP_PASSWORD. Ohne eigene verifizierte Domain sendet
# Resend nur von onboarding@resend.dev an die beim Resend-Account hinterlegte
# Adresse — für Einzelnutzer-Betrieb ausreichend.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_FROM=onboarding@resend.dev
